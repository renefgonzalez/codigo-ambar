# ─────────────────────────────────────────────────────────────
# Código Ámbar — Variables de entorno
# Copia este archivo a ".env" y rellena con tus credenciales.
# (Vite solo expone variables con el prefijo VITE_)
# ─────────────────────────────────────────────────────────────

# Número del asesor que recibirá las cotizaciones por WhatsApp.
# Formato internacional sin "+", espacios ni guiones. Ej. México: 521XXXXXXXXXX
VITE_WHATSAPP_NUMBER=521XXXXXXXXXX

# Supabase (preparado para futuro backend)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
